# Keep machine- and site-specific directory mappings outside this repo.
#
# Example ~/.gitconfig.local:
#
# [includeIf "gitdir:~/git/somesite/**"]
#   path = ~/.gitconfig-somesite
#
# Each included file can contain:
#
# [user]
#   name = Your Name
#   email = you@example.com
#
# [core]
#   sshCommand = ssh -i ~/.ssh/id_example -o IdentitiesOnly=yes
#
[include]
  path = ~/.gitconfig.local

[alias]
	co = checkout
	br = branch
	st = status
	pm = pull origin main

[color]
	ui = auto
